rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. GLOBAL SAFETY NET - Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. REUSABLE SECURITY PRIMITIVES & HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    // Lookup admins collection to verify administrative privilege
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Bootstrap administrator to write initial record in database
    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == "awalelian22@gmail.com";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() >= 1 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. ENTITY VALIDATIONS

    // Admin validation blueprint
    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'uid', 'createdAt'])
        && data.keys().size() == 3
        && data.email is string
        && data.email.size() > 0
        && data.email.size() <= 256
        && data.uid is string
        && data.uid == request.auth.uid;
    }

    // Notice validation blueprint
    function isValidNotice(data) {
      return data.keys().hasAll(['id', 'title', 'date', 'category', 'content', 'createdAt'])
        && data.id is string
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.date is string
        && data.category is string
        && data.category in ['admission', 'academic', 'routine', 'event', 'general']
        && data.content is string
        && data.content.size() <= 5000;
    }

    // Program validation blueprint
    function isValidProgram(data) {
      return data.keys().hasAll(['id', 'title', 'type', 'description', 'duration', 'eligibility', 'icon', 'image', 'features', 'createdAt'])
        && data.id is string
        && data.title is string
        && data.title.size() <= 150
        && data.type is string
        && data.description is string
        && data.description.size() <= 5000
        && data.duration is string
        && data.eligibility is string
        && data.icon is string
        && data.image is string
        && data.image.size() <= 2048
        && data.features is list
        && data.features.size() <= 15;
    }

    // Gallery item validation blueprint
    function isValidGalleryItem(data) {
      return data.keys().hasAll(['id', 'title', 'category', 'image', 'description', 'createdAt'])
        && data.id is string
        && data.title is string
        && data.title.size() <= 200
        && data.category is string
        && data.category in ['campus', 'academic', 'activity', 'event']
        && data.image is string
        && data.image.size() <= 2048
        && data.description is string
        && data.description.size() <= 1000;
    }

    // Testimonial validation blueprint
    function isValidTestimonial(data) {
      return data.keys().hasAll(['id', 'name', 'role', 'content', 'image', 'rating', 'createdAt'])
        && data.id is string
        && data.name is string
        && data.name.size() <= 100
        && data.role is string
        && data.role in ['Student', 'Alumni', 'Parent']
        && data.content is string
        && data.content.size() <= 2000
        && data.image is string
        && data.image.size() <= 2048
        && data.rating is number
        && data.rating >= 1
        && data.rating <= 5;
    }

    // Stat / Achievement validation blueprint
    function isValidStat(data) {
      return data.keys().hasAll(['id', 'label', 'value', 'suffix', 'icon', 'createdAt'])
        && data.id is string
        && data.label is string
        && data.label.size() > 0
        && data.label.size() <= 100
        && data.value is number
        && data.suffix is string
        && data.suffix.size() <= 10
        && data.icon is string;
    }

    // Admission application validation blueprint (Public write, Admin read/update)
    function isValidAdmission(data) {
      return data.keys().hasAll(['id', 'fullName', 'email', 'phone', 'program', 'previousExam', 'gpa', 'status', 'appliedDate', 'createdAt'])
        && data.id is string
        && data.fullName is string
        && data.fullName.size() > 0
        && data.fullName.size() <= 200
        && data.email is string
        && data.email.size() > 0
        && data.email.size() <= 256
        && data.phone is string
        && data.phone.size() <= 50
        && data.program is string
        && data.previousExam is string
        && data.gpa is string
        && data.status is string
        && data.status in ['pending', 'approved', 'under_review', 'rejected']
        && data.appliedDate is string;
    }

    // Site settings document blueprint
    function isValidSiteSetting(data) {
      return data.keys().hasAll(['id', 'content', 'updatedAt'])
        && data.id is string
        && data.content is map;
    }


    // 4. COLLECTION PORTALS

    // Admins Collection
    match /admins/{adminId} {
      allow get: if isSignedIn() && (isBootstrapAdmin() || isAdmin());
      allow list: if isSignedIn() && (isBootstrapAdmin() || isAdmin());
      // A bootstrap email can write to seed their own admin credentials
      allow create: if isSignedIn() && isBootstrapAdmin() && isValidAdmin(incoming());
      allow update: if isSignedIn() && isAdmin() && isValidAdmin(incoming()) && incoming().uid == existing().uid;
      allow delete: if false; // Admins cannot be deleted from the client to prevent total lockouts
    }

    // Notices CMS Collection
    match /notices/{noticeId} {
      allow get, list: if true; // Public list and get
      allow create: if isAdmin() && isValidNotice(incoming()) && isValidId(noticeId);
      allow update: if isAdmin() && isValidNotice(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    // Programs Collection
    match /programs/{programId} {
      allow get, list: if true; // Public list and get
      allow create: if isAdmin() && isValidProgram(incoming()) && isValidId(programId);
      allow update: if isAdmin() && isValidProgram(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    // Gallery Collection
    match /gallery/{itemId} {
      allow get, list: if true; // Public list and get
      allow create: if isAdmin() && isValidGalleryItem(incoming()) && isValidId(itemId);
      allow update: if isAdmin() && isValidGalleryItem(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    // Testimonials Collection
    match /testimonials/{testimonialId} {
      allow get, list: if true; // Public list and get
      allow create: if isAdmin() && isValidTestimonial(incoming()) && isValidId(testimonialId);
      allow update: if isAdmin() && isValidTestimonial(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    // Statistics Collection
    match /stats/{statId} {
      allow get, list: if true; // Public list and get
      allow create: if isAdmin() && isValidStat(incoming()) && isValidId(statId);
      allow update: if isAdmin() && isValidStat(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    // Admissions Forms Collection
    match /admissions/{applicationId} {
      allow create: if isValidAdmission(incoming()) && incoming().status == 'pending' && isValidId(applicationId);
      // Once written, ONLY verified administrators can review or manage candidate details
      allow get, list: if isAdmin();
      allow update: if isAdmin() && isValidAdmission(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    // Configuration / Theme Settings Collection
    match /site_settings/{docId} {
      allow get: if true; // Public reads config
      allow list: if true; // Public listing config doc
      allow create, update: if isAdmin() && isValidSiteSetting(incoming()) && isValidId(docId);
      allow delete: if false; // System configs must remain intact
    }
  }
}
